{
  "name": "@ducheved/neko-lucia",
  "version": "0.1.0",
  "description": "Modern server-side sessions with Lucia v3 migration support",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm --dir ../.. format && pnpm --dir ../.. lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "neko-lucia",
    "session",
    "authentication",
    "auth"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ducheved/neko-lucia.git",
    "directory": "packages/lucia"
  },
  "author": "Ducheved",
  "contributors": [
    "pilcrowonpaper (original Lucia author)"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ducheved/neko-lucia#readme",
  "bugs": {
    "url": "https://github.com/Ducheved/neko-lucia/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "deno": ">=2.9.0",
    "node": "^22.23.1 || ^24.18.0 || ^26.0.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  }
}
