{
  "name": "@ducheved/neko-lucia-adapter-drizzle",
  "version": "0.1.0",
  "description": "Drizzle ORM adapter for @ducheved/neko-lucia",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
