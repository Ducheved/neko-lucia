{
  "name": "@ducheved/neko-lucia-adapter-drizzle",
  "version": "0.1.0",
  "description": "Drizzle ORM adapters for @ducheved/neko-lucia",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm --dir ../.. lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "neko-lucia",
    "drizzle",
    "postgres",
    "session",
    "adapter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ducheved/neko-lucia.git",
    "directory": "packages/adapter-drizzle"
  },
  "author": "Ducheved",
  "contributors": [
    "pilcrowonpaper (original Lucia author)"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ducheved/neko-lucia#readme",
  "bugs": {
    "url": "https://github.com/Ducheved/neko-lucia/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "deno": ">=2.9.0",
    "node": "^22.23.1 || ^24.18.0 || ^26.0.0"
  },
  "peerDependencies": {
    "@ducheved/neko-lucia": "0.1.0",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@ducheved/neko-lucia": "workspace:*",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "better-sqlite3": "12.11.1",
    "drizzle-orm": "0.45.2",
    "mysql2": "3.23.0",
    "pg": "8.22.0",
    "typescript": "7.0.2"
  }
}
